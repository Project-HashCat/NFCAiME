CARD_SERVER_HOST=0.0.0.0
CARD_SERVER_PORT=8000
SPAD0_RSA_PRIVATE_KEY_FILE=/etc/nfcaime/spad0_private_key.pem
DEBUG_LOG_SECRET=NFCAimeDebugLog-v1

# Optional. If set, POST /card forwards decrypted card records to this URL.
# The webhook response JSON is merged into the app response.
NFCAIME_CARD_WEBHOOK_URL=
NFCAIME_CARD_WEBHOOK_TOKEN=
